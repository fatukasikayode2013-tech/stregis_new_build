SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@stregishotelandresort.com
SMTP_PASS=your-smtp-password

# Alternative Zoho Configuration
ZOHO_HOST=smtp.zoho.com
ZOHO_PORT=587
ZOHO_SECURE=false
ZOHO_USER=your-email@stregishotelandresort.com
ZOHO_PASS=your-smtp-password

# Site Configuration
